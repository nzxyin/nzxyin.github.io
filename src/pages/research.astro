---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('research')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Research | Your Name" description="Research papers and publications.">
	<h1>Research</h1>
	{
		papers.map((paper) => (
			<article class="paper">
				<h2>{paper.data.title}</h2>
				<p class="meta">
					{paper.data.authors} &mdash; {paper.data.venue},{' '}
					{paper.data.date.getFullYear()}
				</p>
				<p>{paper.data.abstract}</p>
				<p class="links">
					{paper.data.pdfUrl && <a href={paper.data.pdfUrl}>PDF</a>}
					{paper.data.codeUrl && <a href={paper.data.codeUrl}>Code</a>}
					{paper.data.doiUrl && <a href={paper.data.doiUrl}>DOI</a>}
				</p>
			</article>
		))
	}
</Layout>

<style>
	.paper {
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--color-border);
	}

	.paper:last-child {
		border-bottom: none;
	}

	.meta {
		color: var(--color-muted);
		font-size: 0.9rem;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	.links a {
		margin-right: 1rem;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		font-size: 0.9rem;
	}
</style>
