---
interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Personal site and research portfolio.' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav>
				<a class="brand" href="/">Xavier Yin</a>
				<div class="links">
					<a href="/research">Research</a>
					<a href="/blog">Blog</a>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>&copy; {new Date().getFullYear()} Xavier Yin</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #ffffff;
		--color-text: #1a1a1a;
		--color-muted: #6b6b6b;
		--color-border: #e5e5e5;
		--color-accent: #2563eb;
		--content-width: 42rem;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--color-bg: #111113;
			--color-text: #e8e8e8;
			--color-muted: #9a9a9a;
			--color-border: #2a2a2e;
			--color-accent: #6ea8fe;
		}
	}

	* {
		box-sizing: border-box;
	}

	html {
		font-family: 'Georgia', 'Iowan Old Style', serif;
	}

	body {
		margin: 0;
		background: var(--color-bg);
		color: var(--color-text);
		line-height: 1.6;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	a {
		color: var(--color-accent);
	}

	header {
		border-bottom: 1px solid var(--color-border);
	}

	nav {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 1.25rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	nav .brand {
		font-weight: 600;
		text-decoration: none;
		color: var(--color-text);
	}

	nav .links a {
		margin-left: 1.5rem;
		text-decoration: none;
		color: var(--color-text);
		font-size: 0.95rem;
	}

	nav .links a:hover {
		color: var(--color-accent);
	}

	main {
		flex: 1;
		width: 100%;
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 2.5rem 1.5rem;
	}

	footer {
		border-top: 1px solid var(--color-border);
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	footer p {
		max-width: var(--content-width);
		margin: 0 auto;
		padding: 1.25rem 1.5rem;
	}

	h1, h2, h3 {
		line-height: 1.25;
	}
</style>
